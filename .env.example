NODE_ENV=development
PORT=8080

# --- JWT (RS256) — solo verificación, solo clave PÚBLICA ---
# Por defecto se lee del archivo; para inyectarla como variable (producción/SOPS)
# define JWT_PUBLIC_KEY con el PEM inline (saltos como \n): tiene prioridad.
JWT_PUBLIC_KEY_PATH=certs/public.pem
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
JWT_ISSUER=auth-service
JWT_AUDIENCE=crm-api

# --- Servicios downstream ---
AUTH_SERVICE_URL=http://localhost:3001
# IDENTITY_SERVICE_URL=http://localhost:3002        # (futuro)
# ORGANIZATION_SERVICE_URL=http://localhost:3003    # (futuro)

# --- CORS ---
CORS_ORIGIN=http://localhost:5173

# --- Rate limit (in-memory) ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
